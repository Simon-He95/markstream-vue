{
  "name": "markstream-svelte",
  "type": "module",
  "version": "0.0.1",
  "description": "Svelte 5 and SvelteKit streaming Markdown renderer for AI chat, LLM token streams, SSE/WebSocket output, incomplete Markdown, Mermaid, KaTeX, Monaco-powered code blocks, and custom Svelte components.",
  "author": "Simon He",
  "license": "MIT",
  "homepage": "https://markstream.simonhe.me/frameworks/svelte",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Simon-He95/markstream-vue.git",
    "directory": "packages/markstream-svelte"
  },
  "bugs": {
    "url": "https://github.com/Simon-He95/markstream-vue/issues"
  },
  "keywords": [
    "svelte",
    "svelte5",
    "sveltekit",
    "markdown",
    "markdown-renderer",
    "svelte-markdown",
    "svelte-markdown-renderer",
    "svelte5-markdown",
    "sveltekit-markdown",
    "svelte-streaming-markdown",
    "svelte-ai-chat",
    "streaming-markdown",
    "ai-markdown-renderer",
    "ai-chat",
    "llm",
    "llm-markdown",
    "llm-streaming",
    "sse",
    "sse-markdown",
    "websocket",
    "websocket-markdown",
    "incomplete-markdown",
    "mermaid",
    "streaming-mermaid",
    "katex",
    "streaming-katex",
    "streaming-code-blocks",
    "d2",
    "infographic",
    "monaco-editor",
    "large-documents",
    "custom-components",
    "beta",
    "markstream-svelte",
    "markstream"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "svelte": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./index.css": "./dist/index.css",
    "./index.px.css": "./dist/index.px.css",
    "./index.tailwind.css": "./dist/index.tailwind.css",
    "./workers/katexRenderer.worker": "./dist/workers/katexRenderer.worker.js",
    "./workers/mermaidParser.worker": "./dist/workers/mermaidParser.worker.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm --dir ../markstream-core build && svelte-package -i src -o dist && postcss src/index.css -o dist/index.css && cp dist/index.css dist/index.tailwind.css && node ../../scripts/generate-px-css.mjs",
    "dev": "vite dev",
    "preview": "vite preview",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "prepublishOnly": "pnpm run build && pnpm run check:workspace-deps-published",
    "check:core-published": "node ../../scripts/check-core-published.mjs --package-json package.json --core-package-json ../markstream-core/package.json",
    "check:workspace-deps-published": "node ../../scripts/check-workspace-deps-published.mjs --package-json package.json",
    "release": "pnpm run check:workspace-deps-published && bumpp --all --commit --no-tag --no-push --execute 'pnpm --workspace-root run docs:llms:generate' && pnpm publish --access public && node ../../scripts/tag-package.mjs --package-json package.json --push"
  },
  "peerDependencies": {
    "@antv/infographic": "^0.2.3",
    "@terrastruct/d2": ">=0.1.33",
    "katex": ">=0.16.22",
    "mermaid": ">=11",
    "stream-diffs": ">=0.0.1",
    "stream-monaco": ">=0.0.48",
    "svelte": ">=5 <6"
  },
  "peerDependenciesMeta": {
    "@antv/infographic": {
      "optional": true
    },
    "@terrastruct/d2": {
      "optional": true
    },
    "katex": {
      "optional": true
    },
    "mermaid": {
      "optional": true
    },
    "stream-diffs": {
      "optional": true
    },
    "stream-monaco": {
      "optional": true
    }
  },
  "dependencies": {
    "@floating-ui/dom": "^1.8.0",
    "markstream-core": "workspace:*",
    "stream-markdown-parser": "workspace:*"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/node": "^18.19.130",
    "autoprefixer": "^10.5.2",
    "postcss-cli": "^11.0.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^7.3.6"
  }
}
