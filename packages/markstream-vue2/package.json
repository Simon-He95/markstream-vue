{
  "name": "markstream-vue2",
  "type": "module",
  "version": "0.0.50",
  "description": "Vue 2.6/2.7 streaming Markdown renderer for AI chat, LLM token streams, SSE/WebSocket output, incomplete Markdown, Mermaid, KaTeX, Shiki, and Vue 2 component rendering.",
  "author": "Simon He",
  "license": "MIT",
  "homepage": "https://markstream.simonhe.me/frameworks/vue2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Simon-He95/markstream-vue.git",
    "directory": "packages/markstream-vue2"
  },
  "bugs": {
    "url": "https://github.com/Simon-He95/markstream-vue/issues"
  },
  "keywords": [
    "vue2",
    "vue-2",
    "vue",
    "vue2.6",
    "vue2.7",
    "markdown",
    "markdown-to-html",
    "markdown-renderer",
    "vue-markdown",
    "vue-markdown-renderer",
    "vue-markdown-component",
    "vue2-markdown",
    "vue2-streaming-markdown",
    "vue2-ai-chat",
    "vue2-llm-markdown",
    "vue2-sse-markdown",
    "vue2-websocket-markdown",
    "vue2-composition-api",
    "vue-demi",
    "legacy-vue2",
    "markdown-preview",
    "markdown-viewer",
    "vue-component",
    "nuxt",
    "nuxt2",
    "nuxt-2",
    "vite",
    "webpack",
    "streaming-markdown",
    "ai-chat",
    "llm",
    "llm-streaming",
    "sse",
    "sse-markdown",
    "websocket",
    "websocket-markdown",
    "incomplete-markdown",
    "html",
    "renderer",
    "custom-component",
    "mermaid",
    "streaming-mermaid",
    "progressive-mermaid",
    "katex",
    "streaming-katex",
    "shiki",
    "streaming-code-blocks",
    "streaming-diff",
    "diff-codeblock",
    "large-documents",
    "performance",
    "real-time-preview",
    "markstream-vue2",
    "markstream",
    "documentation",
    "docs",
    "content-management",
    "cms",
    "markdown-parser",
    "md-to-html",
    "vue2-component"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./index.css": "./dist/index.css",
    "./index.px.css": "./dist/index.px.css",
    "./index.tailwind.css": "./dist/index.tailwind.css",
    "./tailwind": "./dist/tailwind.ts",
    "./workers/katexRenderer.worker": "./dist/workers/katexRenderer.worker.js",
    "./workers/mermaidParser.worker": "./dist/workers/mermaidParser.worker.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm --dir ../markstream-core build && vite build -c vite.config.ts --mode npm && vite build -c vite.config.tailwind.ts --mode npm && node ./scripts/copy-tailwind-css.mjs && node ../../scripts/generate-px-css.mjs && pnpm run build:dts && pnpm run validate:dist",
    "build:analyze": "ANALYZE=true pnpm build",
    "build:dts": "rollup -c ./scripts/rollup.dts.config.mjs && node ./scripts/clean-dts.cjs",
    "validate:dist": "node ./scripts/validate-dist-entries.mjs",
    "size:check": "MAX_PACK_UNPACKED_BYTES=800000 node ../../scripts/check-package-size.mjs",
    "check:core-published": "node ../../scripts/check-core-published.mjs --package-json package.json --core-package-json ../markstream-core/package.json",
    "check:workspace-deps-published": "node ../../scripts/check-workspace-deps-published.mjs --package-json package.json",
    "release": "pnpm run check:workspace-deps-published && bumpp --all --commit --no-tag --no-push --execute 'pnpm --workspace-root run docs:llms:generate' && pnpm publish --access public $(node ../../scripts/dist-tag.mjs) && node ../../scripts/tag-package.mjs --package-json package.json --push"
  },
  "peerDependencies": {
    "@antv/infographic": "^0.2.3",
    "@terrastruct/d2": ">=0.1.33",
    "@vue/composition-api": ">=1.7.2",
    "katex": ">=0.16.22",
    "mermaid": ">=11",
    "stream-markdown": ">=0.0.16",
    "stream-monaco": ">=0.0.48",
    "vue": ">=2.6.14 <3",
    "vue-i18n": ">=9"
  },
  "peerDependenciesMeta": {
    "@antv/infographic": {
      "optional": true
    },
    "@terrastruct/d2": {
      "optional": true
    },
    "@vue/composition-api": {
      "optional": true
    },
    "katex": {
      "optional": true
    },
    "mermaid": {
      "optional": true
    },
    "stream-markdown": {
      "optional": true
    },
    "stream-monaco": {
      "optional": true
    },
    "vue-i18n": {
      "optional": true
    }
  },
  "dependencies": {
    "@floating-ui/dom": "^1.8.0",
    "markstream-core": "workspace:*",
    "stream-markdown-parser": "workspace:*",
    "vue-demi": "^0.14.10"
  },
  "devDependencies": {
    "@vitejs/plugin-vue2": "^2.3.4",
    "@vue/compiler-sfc": "2.7.16",
    "rollup": "^3.30.0",
    "rollup-plugin-dts": "^5.3.1",
    "rollup-plugin-visualizer": "^6.0.11",
    "typescript": "^5.9.3",
    "vite": "^4.5.14",
    "vite-plugin-dts": "^4.5.4",
    "vue-tsc": "^2.2.12"
  }
}
