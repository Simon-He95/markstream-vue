{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "ES2022"],
    "useDefineForClassFields": false,
    "experimentalDecorators": true,
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "stream-markdown-parser": ["../markdown-parser/src/index.ts"],
      "stream-markdown-parser/*": ["../markdown-parser/src/*"],
      "markstream-core": ["../markstream-core/src/index.ts"],
      "markstream-core/*": ["../markstream-core/src/*"]
    },
    "types": ["vite/client"],
    "strict": false,
    "declaration": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
